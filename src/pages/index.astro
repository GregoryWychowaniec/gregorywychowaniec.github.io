---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import heroImage from '../../static/images/hero.jpg';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: site.name,
    url: site.url,
    email: site.email,
    sameAs: [site.linkedin, site.github],
    jobTitle: 'Directeur de la technologie (CTO) - Cybersécurité',
    knowsAbout: [
      'Cybersécurité',
      'SOC managé',
      'Architecture sécurité',
      'Détection',
      'Analyse forensique',
      'Automatisation',
      'Cloud',
      'Intelligence Artificielle',
      'IA appliquée cyber/SOC',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
  },
];

const experiences = [
  {
    role: 'Directeur de la technologie (CTO)',
    company: 'Zero Trust',
    url: 'https://www.zerotrust.fr/',
    date: 'Depuis mars 2026',
    items: [
      'Vision technique et architecture pour un SOC managé On-Premise et Cloud.',
      'Définition de la roadmap, des arbitrages d\'architecture et des orientations techniques.',
      'Industrialisation des capacités de détection : règles Sigma, automatisation, collecteurs de logs et prototypes IA.',
      'Référent technique auprès des analystes SOC : bonnes pratiques, documentation, veille menaces et appui aux investigations complexes.',
    ],
  },
  {
    role: 'Ingénieur cybersécurité',
    company: 'Zero Trust',
    url: 'https://www.zerotrust.fr/',
    date: 'Fév. 2022 - Fév. 2026',
    items: [
      'Gestion opérationnelle de tickets pour un SOC managé On-Premise et Cloud.',
      'Appui aux investigations et analyses forensiques clients.',
      'Développement et amélioration des outils SOC : règles Sigma, automatisation et collecteurs de logs.',
      'Enrichissement des capacités de détection par la veille failles et attaques.',
      'MCO des infrastructures Elasticsearch, Kubernetes et Proxmox.',
      'Formation des nouveaux analystes.',
    ],
  },
  {
    role: 'Stage de Mastère Spécialisé',
    company: 'SPIE Industrie',
    url: 'https://www.spie.fr/fr/nos-filiales/spie-industrie',
    date: 'Avr 2021 - Sept 2021',
    items: [
      'Conception d\'un outil de gestion des vulnérabilités avec Django.',
      'Contribution à l\'analyse des risques en cybersécurité industrielle.',
      'Création d\'accès distants VPN Stormshield et Fortinet.',
    ],
  },
  {
    role: 'Stage de 3e année d\'ingénieur',
    company: 'SII',
    url: 'https://sii-group.com/fr-FR',
    date: 'Avr 2020 - Août 2020',
    text: 'Analyse des risques (EBIOS RM), rédaction DAT, implémentation réseaux (FW, IDS) et services (AD, SFTP).',
  },
];

const olderExperiences = [
  {
    role: 'Stage 2e année d\'ingénieur - CIPAM',
    date: 'Avr 2019 - Août 2019',
    text: 'Programmation embarquée (Pascal), application Android Bluetooth, GPS et Sigfox.',
  },
  {
    role: 'Stage 2e année DUT - DT du Grésivaudan',
    date: 'Avr 2017 - Juin 2017',
    text: 'Création base de données Access/VBA pour gestion des agents territoriaux.',
  },
];

const education = [
  {
    title: 'Mastère Spécialisé Cybersécurité du Numérique',
    school: 'INSA, Lyon',
    url: 'https://www.insa-lyon.fr/fr/mastere-cybersecurite-numerique',
    date: '2020 - 2021',
  },
  {
    title: 'Diplôme d\'ingénieur en Informatique',
    school: 'ISIMA, Clermont-Ferrand',
    url: 'https://www.isima.fr/',
    date: '2017 - 2020',
    detail: 'Filière Réseaux & Sécurité',
  },
  {
    title: 'DUT Informatique',
    school: 'IUT2 Grenoble',
    url: 'https://formations.univ-grenoble-alpes.fr/plugins/odf-web/odf/_content/program-dut-informatique-2-6-2/BUT%20Informatique%20_%20Grenoble.pdf',
    date: '2015 - 2017',
  },
  {
    title: 'Baccalauréat Scientifique',
    school: 'Lycée Honoré Romane, Embrun',
    date: '2015',
  },
];

const skillGroups = [
  {
    title: 'Architecture SOC & cloud',
    skills: ['SOC managé', 'On-Premise', 'Cloud', 'PKI', 'SSO', 'Docker', 'Kubernetes', 'Proxmox', 'Azure', 'GCP', 'AWS'],
  },
  {
    title: 'Détection & automatisation',
    skills: ['Elasticsearch', 'Sigma', 'Elastalert', 'XDR', 'Wazuh', 'Collecteurs de logs', 'Automatisation', 'CI/CD'],
  },
  {
    title: 'Investigation & sécurité offensive',
    skills: ['DFIR', 'Autopsy', 'Reverse engineering', 'Kali', 'Nmap', 'Burp', 'Metasploit', 'CTF', 'Bug bounty'],
  },
  {
    title: 'Langages, normes & méthodes',
    skills: ['Python', 'Go', 'Java', 'Web', 'Assembleur', 'Git', 'ISO 27001', 'EBIOS RM'],
  },
];

const aiSkills = ['LLM', 'RAG', 'Agents IA', 'Bases vectorielles', 'Prompt engineering', 'LangChain', 'MCP'];

const interests = [
  { title: 'Course & Trail', text: 'Pratique régulière', icon: 'landscape' },
  { title: 'Ski', text: 'Montagne', icon: 'downhill_skiing' },
  { title: 'Volley-ball', text: 'Central régional', icon: 'sports_volleyball' },
  { title: 'Développement', text: 'Personnel & Santé', icon: 'nutrition' },
];
---

<BaseLayout title={site.title} description={site.description} jsonLd={jsonLd}>
  <section class="grid grid-cols-1 items-center gap-12 py-20 md:py-32 lg:grid-cols-12">
    <div class="lg:col-span-7">
      <p class="mb-6 inline-flex items-center gap-2 border border-cyber-cyan/20 bg-cyber-cyan/10 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.2em] text-cyber-cyan">
        <span class="h-2 w-2 animate-pulse bg-cyber-cyan"></span>
        Bienvenue, je suis
      </p>
      <h1 class="mb-6 font-headline text-[48px] font-bold leading-[1.05] tracking-normal text-white md:text-headline-xl">
        Grégory<span class="text-cyber-cyan">.</span>
      </h1>
      <p class="mb-10 max-w-xl text-body-lg leading-relaxed text-on-surface-variant">
        CTO cybersécurité, orienté SOC managé On-Premise et Cloud, architecture sécurité, industrialisation de la détection, automatisation et IA appliquée aux usages cyber.
      </p>
      <div class="flex flex-wrap gap-4">
        <a class="button-cyber" href="/files/CV_Gregory_Wychowaniec.pdf" download>Télécharger mon CV</a>
        <a class="button-cyber secondary" href={`mailto:${site.email}`}>Me contacter</a>
      </div>
    </div>

    <aside class="group relative lg:col-span-5" aria-label="Présentation">
      <div class="cyber-border bg-surface-container p-4 backdrop-blur-sm">
        <div class="relative aspect-[4/3] overflow-hidden border border-white/5 bg-white">
          <Image
            src={heroImage}
            alt="Portrait pixel art de Grégory Wychowaniec"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="pixel-art h-full w-full object-cover brightness-110"
          />
        </div>
      </div>
      <div class="mt-6 border-l-2 border-cyber-cyan bg-surface-container/50 p-4">
        <h2 class="font-headline text-lg font-bold text-white">Cybersécurité, SOC managé et IA appliquée</h2>
        <p class="mt-2 text-sm leading-relaxed text-on-surface-variant">
          Mon parcours s'est construit autour de la sécurité opérationnelle, de l'architecture SOC, de la détection, de la veille et de l'amélioration continue.
        </p>
      </div>
      <div class="absolute -right-4 -top-4 -z-10 h-12 w-12 border-r-2 border-t-2 border-white/10 transition-colors group-hover:border-cyber-cyan"></div>
      <div class="absolute -bottom-4 -left-4 -z-10 h-12 w-12 border-b-2 border-l-2 border-white/10 transition-colors group-hover:border-cyber-cyan"></div>
    </aside>
  </section>

  <section class="border-t border-white/5 py-24" id="presentation">
    <div class="mb-16 max-w-3xl">
      <p class="section-kicker">// À propos</p>
      <h2 class="mb-6 font-headline text-section-header text-white">Un profil technique orienté architecture, terrain et détection.</h2>
      <p class="text-lg leading-relaxed text-on-surface-variant">
        J'ai une expérience solide en SOC managé, architecture sécurité, analyse forensique, automatisation et développement d'outils de détection. J'aime comprendre les systèmes, documenter les choix techniques et construire des solutions fiables pour les équipes opérationnelles.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      <article class="cyber-border bg-surface-container/30 p-8">
        <h3 class="mb-6 flex items-center gap-3 font-headline font-bold text-white">
          <span class="material-symbols-outlined text-cyber-cyan" aria-hidden="true">terminal</span>
          Socle technique
        </h3>
        <div class="space-y-5">
          {
            skillGroups.map((group) => (
              <div>
                <p class="mb-2 font-mono text-[10px] uppercase tracking-[0.2em] text-cyber-cyan">{group.title}</p>
                <div class="flex flex-wrap gap-2">
                  {group.skills.map((skill) => <span class="tech-badge">{skill}</span>)}
                </div>
              </div>
            ))
          }
        </div>
        <div class="my-6 h-px bg-cyber-cyan/20"></div>
        <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.2em] text-cyber-cyan">Exploration IA</p>
        <div class="flex flex-wrap gap-2">
          {aiSkills.map((skill) => <span class="tech-badge">{skill}</span>)}
        </div>
      </article>
      <article class="cyber-border bg-surface-container/30 p-8">
        <h3 class="mb-6 flex items-center gap-3 font-headline font-bold text-white">
          <span class="material-symbols-outlined text-cyber-cyan" aria-hidden="true">neurology</span>
          Transition vers l'IA
        </h3>
        <div class="space-y-4 text-sm leading-relaxed text-on-surface-variant">
          <p>
            J'explore progressivement les usages de l'intelligence artificielle appliqués aux pratiques SOC : aide à la détection, automatisation, synthèse, qualification et enrichissement des investigations.
          </p>
          <p>
            Cette orientation complète mon socle cybersécurité. Elle reste ancrée dans les besoins terrain : réduire le bruit, accélérer l'analyse et garder une démarche responsable.
          </p>
          <p>
            Le <a class="text-cyber-cyan underline-offset-4 hover:underline" href="/blog">[ blog ]</a> me sert de journal public pour documenter ces expérimentations.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="border-t border-white/5 py-24" id="experience">
    <div class="mb-16">
      <p class="section-kicker">// Parcours professionnel</p>
      <h2 class="font-headline text-section-header text-white">Expérience</h2>
    </div>
    <div class="space-y-6">
      {
        experiences.map((experience) => (
          <article class="timeline-item group">
            <div class="cyber-border bg-surface-container-low p-6 transition-all group-hover:translate-x-1">
              <div class="mb-4 flex flex-col justify-between gap-2 md:flex-row md:items-center">
                <div>
                  <h3 class="font-headline text-lg font-bold text-white">{experience.role}</h3>
                  <p class="font-mono text-xs text-cyber-cyan">
                    <a class="hover:underline" href={experience.url} target="_blank" rel="noopener noreferrer">{experience.company}</a>
                  </p>
                </div>
                <span class="w-fit bg-white/5 px-3 py-1 font-mono text-xs text-on-surface-variant">{experience.date}</span>
              </div>
              {experience.items ? (
                <ul class="space-y-2 text-sm text-on-surface-variant">
                  {experience.items.map((item, index) => (
                    <li class="flex gap-2">
                      <span class="font-mono text-cyber-cyan">{String(index + 1).padStart(2, '0')}</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-sm leading-relaxed text-on-surface-variant">{experience.text}</p>
              )}
            </div>
          </article>
        ))
      }
      <div class="grid grid-cols-1 gap-6 pt-4 md:grid-cols-2">
        {
          olderExperiences.map((experience) => (
            <article class="cyber-border bg-surface-container-low p-5">
              <p class="mb-1 font-mono text-[10px] text-on-surface-variant">{experience.date}</p>
              <h3 class="mb-2 text-sm font-bold text-white">{experience.role}</h3>
              <p class="text-xs leading-relaxed text-on-surface-variant">{experience.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 py-24" id="formation">
    <div class="mb-16">
      <p class="section-kicker">// Éducation</p>
      <h2 class="font-headline text-section-header text-white">Formation</h2>
    </div>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        education.map((item) => (
          <article class="cyber-border flex min-h-36 flex-col bg-surface-container/20 p-6">
            <span class="mb-4 font-mono text-xs text-cyber-cyan">{item.date}</span>
            <h3 class="mb-2 text-sm font-bold text-white">{item.title}</h3>
            {item.url ? (
              <a class="mt-auto text-xs text-on-surface-variant hover:text-cyber-cyan" href={item.url} target="_blank" rel="noopener noreferrer">{item.school}</a>
            ) : (
              <p class="mt-auto text-xs text-on-surface-variant">{item.school}</p>
            )}
            {item.detail && <p class="mt-1 text-[10px] text-on-surface-variant/60">{item.detail}</p>}
          </article>
        ))
      }
    </div>
  </section>

  <section class="border-t border-white/5 py-24" id="passions">
    <div class="mb-16">
      <p class="section-kicker">// Équilibre personnel</p>
      <h2 class="font-headline text-section-header text-white">Centres d'intérêt</h2>
    </div>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {
        interests.map((interest) => (
          <article class="cyber-border group bg-surface-container-high p-6 text-center transition-all duration-300 hover:bg-cyber-cyan hover:text-background">
            <span class="material-symbols-outlined mb-3 block text-3xl" aria-hidden="true">{interest.icon}</span>
            <h3 class="text-sm font-bold">{interest.title}</h3>
            <p class="mt-1 text-[10px] opacity-60">{interest.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="border-t border-white/5 py-24 text-center" id="contact">
    <div class="mx-auto max-w-2xl">
      <p class="section-kicker">// Communication</p>
      <h2 class="mb-6 font-headline text-section-header text-white">Entrer en contact</h2>
      <p class="mb-12 text-on-surface-variant">
        Ma boîte mail est ouverte pour échanger autour de la cybersécurité, de l'automatisation, de l'IA ou simplement pour me dire bonjour 👋.
      </p>
      <div class="flex flex-wrap justify-center gap-6">
        <a class="button-cyber" href={`mailto:${site.email}`}>
          <span class="material-symbols-outlined text-lg" aria-hidden="true">mail</span>
          Envoyer un email
        </a>
        <div class="flex gap-4">
          <a class="icon-button" href={site.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V8.98h3.42v1.57h.05c.48-.9 1.64-1.85 3.37-1.85 3.61 0 4.27 2.37 4.27 5.46v6.29ZM5.32 7.41a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.04H3.54V8.98H7.1v11.47ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z" />
            </svg>
          </a>
          <a class="icon-button" href={site.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 .3a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.22c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.47 11.47 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .3Z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

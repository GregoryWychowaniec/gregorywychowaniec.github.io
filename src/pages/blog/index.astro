---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogSlug } from '../../utils/blog';

const posts = (await getCollection('blog')).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = 'Blog technique';
const description =
  'Journal d\'expériences sur la cybersécurité, l\'automatisation, l\'IA, les outils testés, les limites observées et les apprentissages.';
---

<BaseLayout title={title} description={description} canonical="/blog">
  <section class="border-t border-white/5 py-20 md:py-28">
    <div class="mb-16 max-w-3xl">
      <p class="section-kicker">// Blog</p>
      <h1 class="mb-6 font-headline text-[42px] font-bold leading-tight text-white md:text-headline-xl">
        Journal d'expériences<span class="text-cyber-cyan">.</span>
      </h1>
      <p class="text-lg leading-relaxed text-on-surface-variant">
        Des notes publiques pour documenter les tests, les apprentissages, les limites et les retours d'expérience autour de la cybersécurité, de l'automatisation et de l'IA.
      </p>
    </div>

    <div class="grid gap-6">
      {
        posts.map((post) => (
          <article class="cyber-border bg-surface-container-low p-6 transition-all hover:translate-x-1">
            <div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_280px] md:items-center">
              <div>
                <p class="mb-4 font-mono text-xs uppercase tracking-[0.16em] text-cyber-cyan">
                  {post.data.pubDate.toLocaleDateString('fr-FR')} / {post.data.category}
                </p>
                <h2 class="mb-3 font-headline text-2xl font-bold text-white">
                  <a class="hover:text-cyber-cyan" href={`/blog/${getBlogSlug(post)}`}>{post.data.title}</a>
                </h2>
                <p class="max-w-3xl text-sm leading-relaxed text-on-surface-variant">{post.data.description}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => <span class="tech-badge">{tag}</span>)}
                </div>
              </div>
              {
                post.data.image && (
                  <a class="block overflow-hidden border border-cyber-cyan/20 bg-background" href={`/blog/${getBlogSlug(post)}`} aria-label={`Lire l'article : ${post.data.title}`}>
                    <Image
                      src={post.data.image.src}
                      alt={post.data.image.alt}
                      width={post.data.image.width}
                      height={post.data.image.height}
                      loading="lazy"
                      decoding="async"
                      class="aspect-[4/3] h-full w-full object-cover"
                    />
                  </a>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
